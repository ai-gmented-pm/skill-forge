# ============================================================
# forge.ai-gmented.pm — Security headers
# (aligné sur le .htaccess du site maître ; aucun script inline
#  n'est utilisé, la CSP reste donc à script-src 'self')
# ============================================================

ServerSignature Off

<IfModule mod_headers.c>
  Header unset Server
  Header always unset X-Powered-By
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
  # connect-src/img-src : envoi des stats anonymes au Matomo du site maître (sendBeacon + pixel de secours)
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: https://ai-gmented.pm; font-src 'self'; connect-src 'self' https://ai-gmented.pm; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
  Header always set X-XSS-Protection "0"

  # Cache : HTML toujours revalidé, assets rafraîchis sous 5 min (dev actif)
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
  <FilesMatch "\.(css|js|json|md)$">
    Header set Cache-Control "public, max-age=300"
  </FilesMatch>
  <FilesMatch "\.(svg|png|ico|jpg|webp)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
</IfModule>

# Force HTTPS redirect
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Block access to hidden files (.git, .env, etc.)
<FilesMatch "^\.">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

# Allow .well-known directory (Let's Encrypt)
<IfModule mod_rewrite.c>
  RewriteRule "^\.well-known/" - [L]
</IfModule>

# Block PHP execution everywhere except contact.php
<IfModule mod_rewrite.c>
  RewriteCond %{REQUEST_URI} !^/contact\.php$
  RewriteRule \.php$ - [F,L]
</IfModule>
